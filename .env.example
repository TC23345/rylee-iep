# Copy to .env.local and fill in. .env.local is gitignored.

# MongoDB connection string. DB "rylee_iep". V1 stores metadata only.
MONGODB_URI=
MONGODB_DB=rylee_iep

# Clerk (reuse the dashboard's instance). Publishable key is public; secret key is not.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# Optional comma-separated allow-list for mutations outside Clerk organizations.
RYLEE_ADMIN_USER_IDS=
